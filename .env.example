# Copy to `.env` to enable the LLM-as-judge path. Without these, ARA runs the
# offline heuristic scorer (no external calls).

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2024-10-21

# Deployment names for each worker (see the build_llm() factory).
ARA_LLM_SCORER=<your-scorer-deployment>
ARA_LLM_NORMALIZER=<your-normalizer-deployment>

# --- Scoring / verdict (all optional) ---
ARA_RUBRIC_VERSION=2.0-cross-vendor
ARA_DEPLOY_THRESHOLD=7.0
ARA_CONDITIONAL_THRESHOLD=5.0
ARA_STRICT_GATES=true
